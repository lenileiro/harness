diff --git a/src/README.md b/src/README.md
index aa9813a..c0dc962 100644
--- a/src/README.md
+++ b/src/README.md
@@ -9,6 +9,7 @@ A simple stateless calculator.
 - `multiply(a, b)` — product of two numbers
 - `sqrt(x)` — square root of a non-negative number
 - `subtract(a, b)` — `a - b`
+- `power(base, exponent)` — `base` raised to the power of `exponent`
 
 ## Example
 
diff --git a/src/calculator.py b/src/calculator.py
index 9ebe3c5..4920250 100644
--- a/src/calculator.py
+++ b/src/calculator.py
@@ -33,3 +33,7 @@ class Calculator:
         if x < 0:
             raise ValueError("cannot take sqrt of a negative number")
         return math.sqrt(x)
+
+    def power(self, base: float, exponent: float) -> float:
+        """Return `base` raised to the power of `exponent`."""
+        return base ** exponent
