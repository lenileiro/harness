#!/usr/bin/env python3
from __future__ import annotations

from harness.cli import __main__ as cli_main
from harness.core import Capabilities, Done, Message, TextDelta


class FakeAdapter:
    name = "ollama"

    def __init__(self, *args, **kwargs):
        pass

    async def capabilities(self) -> Capabilities:
        return Capabilities(streaming=True, tool_use=True)

    async def cancel(self, session_id: str) -> None:
        return None

    def stream(self, **kwargs):
        return self._stream()

    async def _stream(self):
        yield TextDelta(text="lifecycle bootstrap ok")
        yield Done(final_message=Message(role="assistant", content="lifecycle bootstrap ok"))


cli_main.OllamaAdapter = FakeAdapter

if __name__ == "__main__":
    cli_main.app()
