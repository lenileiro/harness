#!/usr/bin/env python3
from __future__ import annotations

import asyncio
import sys
from pathlib import Path

from harness.cli import __main__ as cli_main
from harness.core import Capabilities, Done, Message, TextDelta
from harness.storage.sqlite import SQLiteStorage


def _db_path(argv: list[str]) -> Path:
    for index, item in enumerate(argv):
        if item == "--db" and index + 1 < len(argv):
            return Path(argv[index + 1])
    return Path(".harness/harness.db")


async def _latest_memory_id(db_path: Path) -> str:
    storage = SQLiteStorage(path=db_path)
    try:
        entries = await storage.list_memory(limit=50)
        if not entries:
            raise RuntimeError("no memory entries found")
        return entries[0].id
    finally:
        await storage.close()


def _resolve_runtime_placeholders(argv: list[str]) -> list[str]:
    if "{latest_memory_id}" not in argv:
        return argv
    latest = asyncio.run(_latest_memory_id(_db_path(argv)))
    return [latest if item == "{latest_memory_id}" else item for item in argv]


class FakeAdapter:
    name = "ollama"
    mode = "run"

    def __init__(self, *args, **kwargs):
        pass

    async def capabilities(self) -> Capabilities:
        return Capabilities(streaming=True, tool_use=True)

    async def cancel(self, session_id: str) -> None:
        return None

    def stream(self, **kwargs):
        return self._stream()

    async def _stream(self):
        if FakeAdapter.mode == "mine":
            response = (
                '{"tips":[{"text":"Persist cleanup learnings as tips after repetitive '
                'failures.","triggers":["workflow cleanup","repetitive failures"]}]}'
            )
        else:
            response = "cleanup mining bootstrap ok"
        yield TextDelta(text=response)
        yield Done(final_message=Message(role="assistant", content=response))


argv = _resolve_runtime_placeholders(sys.argv[1:])
if len(argv) >= 2 and argv[0] == "tips" and argv[1] == "mine":
    FakeAdapter.mode = "mine"

cli_main.OllamaAdapter = FakeAdapter
sys.argv = [sys.argv[0], *argv]

if __name__ == "__main__":
    cli_main.app()
