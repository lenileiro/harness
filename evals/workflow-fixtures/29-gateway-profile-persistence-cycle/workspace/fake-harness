#!/usr/bin/env python3
from __future__ import annotations

import json
import re
from pathlib import Path

import harness.core.gateway_router as gateway_router
from harness.cli import __main__ as cli_main
from harness.cli import gateway_commands
from harness.core.gateway_sessions import GatewaySessionStore


def _slug(value: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", value.lower()).strip("-") or "item"


def _stable_session_id(self, transport: str, user_id: str, thread_id: str) -> str:
    return f"gw-{_slug(transport)}-{_slug(thread_id)}"


class _PopenStub:
    def __init__(self, args, **kwargs) -> None:
        capture = Path.cwd() / ".harness" / "scheduler-launches.jsonl"
        capture.parent.mkdir(parents=True, exist_ok=True)
        with capture.open("a", encoding="utf-8") as handle:
            handle.write(json.dumps({"args": list(args), "cwd": kwargs.get("cwd")}) + "\n")


async def _fake_run_once(**kwargs: object) -> str:
    cwd = Path(str(kwargs["cwd"]))
    capture = cwd / ".harness" / "gateway-converse-capture.json"
    payload = {
        "prompt": str(kwargs.get("prompt", "")),
        "session_id": str(kwargs.get("session_id", "")),
    }
    capture.parent.mkdir(parents=True, exist_ok=True)
    capture.write_text(json.dumps(payload, indent=2), encoding="utf-8")
    prompt = payload["prompt"]
    if (
        "Shared active work for this user:" in prompt
        and "Other recent chats for this user:" in prompt
        and "continue the Tokyo weather follow-up [reminder.once]" in prompt
    ):
        return "shared context ok"
    return "thread summary ok"


GatewaySessionStore.new_id = _stable_session_id  # type: ignore[assignment]
gateway_router.subprocess.Popen = _PopenStub  # type: ignore[assignment]
gateway_commands._run_once_impl = _fake_run_once  # type: ignore[assignment]

if __name__ == "__main__":
    cli_main.app()
